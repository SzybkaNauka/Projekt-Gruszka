{
  "name": "gruszka-katapulta",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 5188 --strictPort",
    "build": "vite build",
    "preview": "vite preview",
    "cap:init": "npx cap init GruszkaKatapulta com.lares.gruszkakatapulta --web-dir=dist",
    "cap:add:android": "npm run build && npx cap add android",
    "cap:add:ios": "npm run build && npx cap add ios",
    "cap:sync": "npm run build && npx cap sync",
    "cap:open:android": "npx cap open android",
    "cap:open:ios": "npx cap open ios"
  },
  "dependencies": {
    "@capacitor/android": "^5.0.0",
    "@capacitor/cli": "^5.0.0",
    "@capacitor/core": "^5.0.0",
    "@capacitor/ios": "^5.0.0",
    "@supabase/supabase-js": "^2.106.0",
    "phaser": "^3.60.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "vite": "^5.0.0"
  }
}
